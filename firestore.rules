rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn()
        && (
          request.auth.token.email_verified == true
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.emailVerified == true
          )
        );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validUsernameLower(usernameLower) {
      return usernameLower is string
        && usernameLower.matches('^[a-z0-9._-]{3,30}$');
    }

    function usernameOwnedBy(uid, usernameLower) {
      return (
          existsAfter(/databases/$(database)/documents/usernames/$(usernameLower))
          && getAfter(/databases/$(database)/documents/usernames/$(usernameLower)).data.uid == uid
        ) || (
          exists(/databases/$(database)/documents/usernames/$(usernameLower))
          && get(/databases/$(database)/documents/usernames/$(usernameLower)).data.uid == uid
        );
    }

    function requestStatusNowIs(requestId, wantedStatus) {
      return exists(/databases/$(database)/documents/friendRequests/$(requestId))
        && get(/databases/$(database)/documents/friendRequests/$(requestId)).data.status == wantedStatus;
    }

    function requestStatusNowOrAfterIs(requestId, wantedStatus) {
      return (
          existsAfter(/databases/$(database)/documents/friendRequests/$(requestId))
          && getAfter(/databases/$(database)/documents/friendRequests/$(requestId)).data.status == wantedStatus
        ) || (
          exists(/databases/$(database)/documents/friendRequests/$(requestId))
          && get(/databases/$(database)/documents/friendRequests/$(requestId)).data.status == wantedStatus
        );
    }

    function hasAcceptedFriendship(uidA, uidB) {
      return requestStatusNowOrAfterIs(uidA + '_' + uidB, 'accepted')
        || requestStatusNowOrAfterIs(uidB + '_' + uidA, 'accepted');
    }

    function isRoomMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function isRoomHost(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId))
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
    }

    // Debug-only: co-op simulator user — never used in production.
    function isSimUser(uid) {
      return uid == 'sim_user_b__debug' || uid == 'sim_user_c__debug';
    }

    function isCurrentRoomHostByField() {
      return isSignedIn()
        && resource.data.hostId == request.auth.uid;
    }

    function roomExistsNowOrAfter(roomId) {
      return existsAfter(/databases/$(database)/documents/rooms/$(roomId))
        || exists(/databases/$(database)/documents/rooms/$(roomId));
    }

    function roomStatusNowOrAfterWaitingOrActive(roomId) {
      return (
          existsAfter(/databases/$(database)/documents/rooms/$(roomId))
          && getAfter(/databases/$(database)/documents/rooms/$(roomId)).data.status in ['waiting', 'active']
        ) || (
          exists(/databases/$(database)/documents/rooms/$(roomId))
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.status in ['waiting', 'active']
        );
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && isVerified()
        && request.resource.data.firebaseUid == uid
        && request.resource.data.role == 'USER'
        && request.resource.data.emailVerified == true
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && validUsernameLower(request.resource.data.usernameLower)
        && usernameOwnedBy(uid, request.resource.data.usernameLower)
        && request.resource.data.friends is list
        && request.resource.data.friends.size() == 0
        && request.resource.data.friendsCount is int
        && request.resource.data.friendsCount == 0;

      allow update: if isOwner(uid);

      allow update: if isVerified() && (
        (
          isOwner(uid)
          && request.resource.data.firebaseUid == uid
          && request.resource.data.role == 'USER'
          && request.resource.data.emailVerified == true
          && request.resource.data.email is string
          && request.resource.data.email == request.auth.token.email
          && validUsernameLower(request.resource.data.usernameLower)
          && usernameOwnedBy(uid, request.resource.data.usernameLower)
        ) ||
        (
          !isOwner(uid)
          && hasAcceptedFriendship(uid, request.auth.uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['friends', 'friendsCount', 'updatedAt']
          )
          && request.resource.data.friends is list
          && resource.data.friends is list
          && request.resource.data.friends.hasAll(resource.data.friends)
          && request.resource.data.friends.hasAll([request.auth.uid])
          && request.resource.data.friends.size() <= resource.data.friends.size() + 1
          && request.resource.data.friendsCount is int
          && resource.data.friendsCount is int
          && request.resource.data.friendsCount >= resource.data.friendsCount
          && request.resource.data.friendsCount <= resource.data.friendsCount + 1
        )
      );

      allow delete: if isOwner(uid);

      match /friends/{friendUid} {
        allow read: if isSignedIn() && (isOwner(uid) || isOwner(friendUid));

        allow create, update: if isSignedIn()
          && (isOwner(uid) || isOwner(friendUid))
          && hasAcceptedFriendship(uid, friendUid)
          && request.resource.data.friendUid == friendUid
          && request.resource.data.keys().hasOnly([
            'friendUid',
            'username',
            'name',
            'surname',
            'email',
            'photoUrl',
            'since'
          ]);

        allow delete: if isSignedIn() && (isOwner(uid) || isOwner(friendUid));
      }

      match /badges/{badgeId} {
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }
    }

    match /usernames/{usernameLower} {
      // Client transaction içinde tx.get(usernames/{usernameLower}) kullanıldığı için read açık olmalı.
      allow read: if isSignedIn();

      allow create: if isVerified()
        && validUsernameLower(usernameLower)
        && request.resource.data.keys().hasOnly(['uid', 'username', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && !exists(/databases/$(database)/documents/usernames/$(usernameLower));

      allow update: if isVerified()
        && validUsernameLower(usernameLower)
        && request.resource.data.keys().hasOnly(['uid', 'username', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && resource.data.uid == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /friendRequests/{requestId} {
      // sendFriendRequest transaction'ında tx.get(...) ile henüz var olmayan
      // friendRequests dokümanları okunuyor. resource == null durumuna izin vermezsek
      // işlem permission-denied ile düşer.
      allow read: if isSignedIn()
        && (
          resource == null
          || resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        );

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'toUid',
          'fromUsername',
          'toUsername',
          'pairKey',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.id == request.resource.data.fromUid + '_' + request.resource.data.toUid;

      allow update: if isSignedIn() && (
        // Alıcı, bekleyen isteği kabul/reddet edebilir.
        (
          request.auth.uid == resource.data.toUid
          && resource.data.status == 'pending'
          && request.resource.data.fromUid == resource.data.fromUid
          && request.resource.data.toUid == resource.data.toUid
          && request.resource.data.status in ['accepted', 'rejected']
        ) ||
        // Gönderen, daha önce reddedilen/iptal edilen isteği tekrar pending'e çekebilir.
        (
          request.auth.uid == resource.data.fromUid
          && resource.data.status in ['rejected', 'cancelled']
          && request.resource.data.fromUid == resource.data.fromUid
          && request.resource.data.toUid == resource.data.toUid
          && request.resource.data.status == 'pending'
        ) ||
        // Gönderen, bekleyen isteğini iptal edebilir (geri çekebilir).
        (
          request.auth.uid == resource.data.fromUid
          && resource.data.status == 'pending'
          && request.resource.data.fromUid == resource.data.fromUid
          && request.resource.data.toUid == resource.data.toUid
          && request.resource.data.status == 'cancelled'
        )
      );

      allow delete: if false;
    }

    match /multiInvites/{inviteId} {
      allow read: if isSignedIn()
        && (resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'toUid',
          'mode',
          'city',
          'status',
          'updatedAt',
          'createdAt'
        ])
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.mode == 'multi'
        && request.resource.data.status == 'pending'
        && request.resource.id == request.resource.data.fromUid + '_' + request.resource.data.toUid
        && hasAcceptedFriendship(request.resource.data.fromUid, request.resource.data.toUid);

      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
          || request.auth.uid == resource.data.toUid)
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.mode == resource.data.mode
        && request.resource.data.city == resource.data.city
        && request.resource.data.status in ['pending', 'accepted', 'rejected', 'cancelled'];

      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow get, list: if isCurrentRoomHostByField() || isRoomMember(roomId);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'hostId',
          'cityId',
          'roomName',
          'status',
          'minPlayers',
          'createdAt'
        ])
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.cityId is string
        && request.resource.data.roomName is string
        && request.resource.data.roomName.size() > 0
        && request.resource.data.status == 'waiting'
        && request.resource.data.minPlayers is int
        && request.resource.data.minPlayers >= 2;

      allow update: if isRoomHost(roomId)
        && isRoomMember(roomId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'hostId',
          'status',
          'updatedAt'
        ])
        && (request.resource.data.status in ['active', 'finished'] || request.resource.data.keys().hasOnly(['hostId', 'updatedAt']))
        && resource.data.status in ['waiting', 'active', 'finished'];

      allow delete: if false;

      match /members/{uid} {
        allow read: if isRoomMember(roomId) || isRoomHost(roomId);

        allow create: if isSignedIn()
          && uid == request.auth.uid
          && roomExistsNowOrAfter(roomId)
          && roomStatusNowOrAfterWaitingOrActive(roomId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.username is string
          && request.resource.data.keys().hasOnly([
            'uid',
            'username',
            'joinedAt'
          ]);

        // Debug sim user: authenticated host can write fake member entry.
        allow create: if isSignedIn()
          && isSimUser(uid)
          && isRoomHost(roomId)
          && request.resource.data.uid == uid
          && request.resource.data.username is string
          && request.resource.data.keys().hasOnly([
            'uid',
            'username',
            'joinedAt'
          ]);

        allow update: if isSignedIn()
          && uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.keys().hasOnly([
            'uid',
            'username',
            'joinedAt'
          ]);

        allow delete: if isSignedIn() && (uid == request.auth.uid || (isSimUser(uid) && isRoomHost(roomId)));
      }

      match /locations/{uid} {
        allow read: if isRoomMember(roomId) || isRoomHost(roomId);

        allow create, update: if isSignedIn()
          && uid == request.auth.uid
          && isRoomMember(roomId)
          && request.resource.data.keys().hasOnly([
            'lat',
            'lng',
            'updatedAt'
          ])
          && request.resource.data.lat is number
          && request.resource.data.lng is number;

        // Debug sim user: host can write fake location entry.
        allow create, update: if isSignedIn()
          && isSimUser(uid)
          && isRoomHost(roomId)
          && request.resource.data.lat is number
          && request.resource.data.lng is number;

        allow delete: if isSignedIn() && (uid == request.auth.uid || (isSimUser(uid) && isRoomHost(roomId)));
      }

      match /presence/{uid} {
        allow read: if isRoomMember(roomId) || isRoomHost(roomId);

        allow create, update: if isSignedIn()
          && uid == request.auth.uid
          && isRoomMember(roomId)
          && request.resource.data.keys().hasOnly([
            'uid',
            'inMap',
            'updatedAt',
            'enteredAt'
          ])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.inMap is bool;

        // Debug sim user: host can write fake presence entry.
        allow create, update: if isSignedIn()
          && isSimUser(uid)
          && isRoomHost(roomId)
          && request.resource.data.uid == uid
          && request.resource.data.inMap is bool;

        allow delete: if isSignedIn() && (uid == request.auth.uid || (isSimUser(uid) && isRoomHost(roomId)));
      }

      match /shared/{docId} {
        allow read: if isRoomMember(roomId) || isRoomHost(roomId);
        allow write: if isRoomMember(roomId) || isRoomHost(roomId);
      }

      match /visits/{venueId} {
        allow read: if isRoomMember(roomId) || isRoomHost(roomId);
        
        allow create, update: if isSignedIn()
          && (isRoomMember(roomId) || isRoomHost(roomId))
          && request.resource.data.keys().hasAll(['venueId', 'visitedBy', 'xpValue', 'visitedAt'])
          && (request.resource.data.visitedBy == request.auth.uid || (isRoomHost(roomId) && isSimUser(request.resource.data.visitedBy)));
          
        allow delete: if false;
      }
    }

    match /invites/{inviteId} {
      allow read: if isSignedIn()
        && (
          resource == null
          ||
          resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid
        );

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'roomId',
          'roomName',
          'fromUserId',
          'fromUsername',
          'toUserId',
          'status',
          'createdAt'
        ])
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.roomName is string
        && request.resource.data.roomName.size() > 0
        && request.resource.data.fromUsername is string
        && request.resource.data.fromUsername.size() > 0
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == 'pending'
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(request.resource.data.toUserId))
        && isRoomHost(request.resource.data.roomId)
        && exists(/databases/$(database)/documents/rooms/$(request.resource.data.roomId));

      allow update: if isSignedIn() && (
        // Alıcı, bekleyen daveti kabul/reddet edebilir
        (
          request.auth.uid == resource.data.toUserId
          && resource.data.status == 'pending'
          && request.resource.data.keys().hasOnly([
            'roomId',
            'roomName',
            'fromUserId',
            'fromUsername',
            'toUserId',
            'status',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.roomId == resource.data.roomId
          && request.resource.data.roomName == resource.data.roomName
          && request.resource.data.fromUserId == resource.data.fromUserId
          && request.resource.data.fromUsername == resource.data.fromUsername
          && request.resource.data.toUserId == resource.data.toUserId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.status in ['accepted', 'rejected']
        ) ||
        // Gönderici, reddedilmiş/kabul edilmiş daveti yeniden gönderebilir
        (
          request.auth.uid == resource.data.fromUserId
          && resource.data.status in ['rejected', 'accepted']
          && isRoomHost(resource.data.roomId)
          && request.resource.data.keys().hasOnly([
            'roomId',
            'roomName',
            'fromUserId',
            'fromUsername',
            'toUserId',
            'status',
            'createdAt'
          ])
          && request.resource.data.fromUserId == resource.data.fromUserId
          && request.resource.data.toUserId == resource.data.toUserId
          && request.resource.data.roomId == resource.data.roomId
          && request.resource.data.status == 'pending'
        )
      );

      allow delete: if false;
    }

    match /userMapStates/{uid} {
      allow read: if isSignedIn() && isOwner(uid);

      allow create, update: if isSignedIn()
        && isOwner(uid);

      allow delete: if false;

      match /states/{mapId} {
        allow read: if isSignedIn() && isOwner(uid);

        allow create, update: if isSignedIn()
          && isOwner(uid);

        allow delete: if isSignedIn()
          && isOwner(uid);
      }
    }

    match /pois/{poiId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /maps/{cityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /pois/{poiId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }


    match /badges/{badgeId} {
      allow read: if isSignedIn();
      // Geçici olarak yazmaya izin verdik ki app ilk açıldığında migration yapabilsin
      allow write: if isSignedIn();
    }

    match /placeSuggestions/{suggestionId} {
      // Sadece kendi önerini okuyabilirsin.
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Giriş yapmış herhangi bir kullanıcı öneri gönderebilir.
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll([
          'userId', 'username', 'latitude', 'longitude',
          'name', 'category', 'mapAreaId', 'status', 'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.mapAreaId is string
        && request.resource.data.status == 'pending';

      // Güncelleme ve silme istemciden yapılamaz (sadece admin / cloud functions).
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
